// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  passwordHash  String?
  avatarUrl     String?
  role          UserRole     @default(USER)
  emailVerified Boolean      @default(false)
  provider      AuthProvider @default(EMAIL)
  providerId    String?
  githubToken   String?
  bio           String?
  website       String?
  company       String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  reviews       Review[]
  teamMembers   TeamMember[]
  notifications Notification[]
  subscription  Subscription?
  auditLogs     AuditLog[]
  sentInvites   TeamInvite[]

  @@index([email])
  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

// ─── Teams ───────────────────────────────────────────────────────────────────

model Team {
  id        String       @id @default(cuid())
  name      String
  slug      String       @unique
  avatarUrl String?
  plan      SubscriptionPlan @default(FREE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  members   TeamMember[]
  projects  Project[]
  invites   TeamInvite[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(cuid())
  role     TeamRole @default(DEVELOPER)
  joinedAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model TeamInvite {
  id        String     @id @default(cuid())
  email     String
  role      TeamRole   @default(DEVELOPER)
  token     String     @unique @default(cuid())
  expiresAt DateTime
  accepted  Boolean    @default(false)
  createdAt DateTime   @default(now())

  teamId    String
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy String
  inviter   User       @relation(fields: [invitedBy], references: [id], onDelete: Cascade)

  @@map("team_invites")
}

enum TeamRole {
  OWNER
  ADMIN
  REVIEWER
  DEVELOPER
}

// ─── Projects & Repositories ─────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  repositories Repository[]
  reviews      Review[]

  @@map("projects")
}

model Repository {
  id            String    @id @default(cuid())
  name          String
  fullName      String
  url           String
  provider      String    @default("github")
  defaultBranch String    @default("main")
  isPrivate     Boolean   @default(false)
  description   String?
  language      String?
  starsCount    Int       @default(0)
  lastScanned   DateTime?
  healthScore   Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  reviews Review[]

  @@map("repositories")
}

// ─── Reviews & Issues ────────────────────────────────────────────────────────

model Review {
  id                   String       @id @default(cuid())
  title                String
  language             String
  sourceType           SourceType
  sourceCode           String
  fileName             String?
  status               ReviewStatus @default(PENDING)
  overallScore         Int?
  qualityScore         Int?
  securityScore        Int?
  performanceScore     Int?
  maintainabilityScore Int?
  optimizedCode        String?
  summary              String?
  aiProvider           String?
  aiModel              String?
  processingTime       Int?
  tokensUsed           Int?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  repositoryId String?
  repository   Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  issues          Issue[]
  recommendations Recommendation[]
  reports         Report[]

  @@index([userId, createdAt])
  @@index([status])
  @@map("reviews")
}

enum SourceType {
  PASTE
  FILE_UPLOAD
  ZIP_UPLOAD
  GITHUB_IMPORT
}

enum ReviewStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Issue {
  id          String        @id @default(cuid())
  type        IssueType
  severity    IssueSeverity
  title       String
  description String
  filePath    String?
  lineStart   Int?
  lineEnd     Int?
  suggestion  String?
  fixedCode   String?
  createdAt   DateTime      @default(now())

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId, severity])
  @@map("issues")
}

enum IssueType {
  BUG
  SECURITY
  PERFORMANCE
  QUALITY
  BEST_PRACTICE
}

enum IssueSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

model Recommendation {
  id          String   @id @default(cuid())
  category    String
  title       String
  description String
  priority    Int      @default(0)
  createdAt   DateTime @default(now())

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("recommendations")
}

// ─── Reports ─────────────────────────────────────────────────────────────────

model Report {
  id        String     @id @default(cuid())
  type      ReportType
  title     String
  content   Json
  fileUrl   String?
  createdAt DateTime   @default(now())

  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum ReportType {
  FULL
  SECURITY
  QUALITY
  EXECUTIVE
}

// ─── Subscriptions & Payments ─────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  scansUsed            Int                @default(0)
  scansLimit           Int                @default(20)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  payments Payment[]

  @@map("subscriptions")
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

model Payment {
  id              String   @id @default(cuid())
  amount          Int
  currency        String   @default("usd")
  status          String
  stripePaymentId String?
  createdAt       DateTime @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

enum NotificationType {
  SCAN_COMPLETE
  SECURITY_ALERT
  TEAM_INVITE
  SUBSCRIPTION
  SYSTEM
}

// ─── Audit Logs ──────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
